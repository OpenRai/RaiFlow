{
  "name": "raiflow",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "scripts": {
    "dev": "pnpm --filter @openrai/site docs:dev",
    "site:dev": "pnpm --filter @openrai/site docs:dev",
    "site:build": "pnpm --filter @openrai/site docs:build",
    "site:preview": "pnpm --filter @openrai/site docs:preview",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
