{
  "name": "@openrai/runtime",
  "version": "0.2.1",
  "private": true,
  "description": "Payment expectation and event runtime for RaiFlow",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "raiflow": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc && node scripts/write-version.mjs",
    "dev": "node ./scripts/dev.mjs",
    "start": "node dist/main.js",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@openrai/config": "workspace:*",
    "@openrai/custody": "workspace:*",
    "@openrai/events": "workspace:*",
    "@openrai/model": "workspace:*",
    "@openrai/nano-core": "2.4.9",
    "@openrai/rpc": "workspace:*",
    "@openrai/storage": "workspace:*",
    "@openrai/webhook": "workspace:*"
  },
  "peerDependencies": {
    "@openrai/watcher": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@openrai/watcher": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
